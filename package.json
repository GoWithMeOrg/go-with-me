{
    "name": "go-with-me",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "pnpm --filter \"*\" build",
        "backend:dev": "pnpm --filter backend nest start --watch",
        "frontend:dev": "pnpm --filter frontend dev",
        "frontend:lint": "pnpm -r exec eslint packages/frontend --fix",
        "backend:lint": "pnpm -r exec eslint packages/backend --fix",
        "frontend:format": "prettier packages/frontend -w",
        "backend:format": "prettier packages/backend -w",
        "import:mongo": "./scripts/import-mongo-data.sh",
        "codegen": "graphql-codegen --config codegen.ts"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^7.1.2",
        "@graphql-codegen/import-types-preset": "^4.0.1",
        "@graphql-codegen/typed-document-node": "^7.0.3",
        "@graphql-codegen/typescript": "^6.0.2",
        "@graphql-codegen/typescript-operations": "^6.0.3",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "class-transformer": "0.5.1",
        "class-validator": "0.15.1",
        "typescript": "5.9.3"
    }
}
